APP_NAME=02_supabase-ai-backend
APP_ENV=local

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional. Used for managed Redis cache/session/rate-limit examples.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Main LLM provider for 01~03 beginner practice.
# Check the current free tier and limits on the official Gemini screen before class.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional. Keep this for comparison or additional OpenAI practice.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

