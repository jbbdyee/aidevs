# 이 파일은 예시입니다.
# 실제 실행할 때는 같은 폴더에 .env 파일을 만들고 실제 값을 넣습니다.

# 이 예제는 Supabase를 사용하지 않습니다.
# 따라서 SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY가 필요 없습니다.

# Upstash Redis REST API URL입니다.
# Upstash Console -> Redis Database -> Details에서 확인합니다.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io

# Upstash Redis REST API token입니다.
# GitHub, README, 캡처 화면에 노출하지 않습니다.
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
