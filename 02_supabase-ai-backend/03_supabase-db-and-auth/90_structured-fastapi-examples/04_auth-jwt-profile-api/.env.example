# 이 파일은 예시입니다.
# 실제 실행할 때는 같은 폴더에 .env 파일을 만들고 실제 값을 넣습니다.

# Supabase 프로젝트 URL입니다.
# Supabase Dashboard -> Project Settings -> API에서 확인합니다.
SUPABASE_URL=https://your-project.supabase.co

# anon key는 로그인한 사용자의 JWT/RLS 흐름을 확인할 때 사용합니다.
# 이 예제에서는 profile 조회/수정 시 사용자 token과 함께 anon key를 사용합니다.
SUPABASE_ANON_KEY=your-anon-key

# service role key는 회원가입/로그인 처리와 서버 측 Supabase client 생성에 사용합니다.
# service role key는 RLS를 우회할 수 있는 서버 전용 관리자 키이므로 GitHub, README, 캡처 화면에 노출하지 않습니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
