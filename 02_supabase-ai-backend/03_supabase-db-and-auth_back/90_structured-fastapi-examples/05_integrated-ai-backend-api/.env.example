# 이 파일은 예시입니다.
# 실제 실행할 때는 같은 폴더에 .env 파일을 만들고 실제 값을 넣습니다.

# Supabase 프로젝트 URL입니다.
# Supabase Dashboard -> Project Settings -> API에서 확인합니다.
SUPABASE_URL=https://your-project.supabase.co

# anon key는 로그인한 사용자의 JWT/RLS 흐름을 확인할 때 사용합니다.
# 이 예제에서는 /logs 조회처럼 사용자 권한으로 접근하는 흐름에 사용합니다.
SUPABASE_ANON_KEY=your-anon-key

# service role key는 서버가 채팅 로그를 저장하는 흐름에 사용합니다.
# service role key는 RLS를 우회할 수 있는 서버 전용 관리자 키이므로 GitHub, README, 캡처 화면에 노출하지 않습니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis REST API 설정입니다. 같은 질문의 AI 답변을 TTL 캐시할 때 사용합니다.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# 처음에는 mock 답변으로 전체 흐름을 확인합니다.
USE_GEMINI=false

# USE_GEMINI=true로 바꿀 때만 실제 Gemini API key가 필요합니다.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
