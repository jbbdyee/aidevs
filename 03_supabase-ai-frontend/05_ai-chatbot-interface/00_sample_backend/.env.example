# 05_ai-chatbot-interface 챗봇 샘플 백엔드 전용 환경변수입니다.
#
# 이 파일은 Streamlit 프론트엔드용 .env가 아닙니다.
# 프론트엔드 화면 코드는 GEMINI_API_KEY를 읽지 않습니다.
# Gemini API key는 FastAPI 백엔드가 실제 Gemini API를 호출할 때만 사용합니다.
#
# 사용 방법:
#   cd C:\aidev\03_supabase-ai-frontend\05_ai-chatbot-interface\00_sample_backend
#   Copy-Item .env.example .env
#
# 그런 다음 .env 파일의 GEMINI_API_KEY 값을 실제 key로 바꿉니다.

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
