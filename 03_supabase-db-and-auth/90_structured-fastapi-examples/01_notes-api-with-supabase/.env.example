# 이 파일은 예시입니다.
# 실제 실행할 때는 같은 폴더에 .env 파일을 만들고 실제 값을 넣습니다.

# Supabase 프로젝트 URL입니다.
# Supabase Dashboard -> Project Settings -> API에서 확인합니다.
SUPABASE_URL=https://your-project.supabase.co

# 이 예제는 FastAPI 백엔드가 서버 권한으로 ex90_notes 테이블을 CRUD합니다.
# 그래서 SUPABASE_ANON_KEY가 아니라 SUPABASE_SERVICE_ROLE_KEY를 사용합니다.
# service role key는 RLS를 우회할 수 있는 서버 전용 관리자 키이므로 GitHub, README, 캡처 화면에 노출하지 않습니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 참고:
# SUPABASE_ANON_KEY는 04_auth-jwt-profile-api, 05_integrated-ai-backend-api처럼
# 로그인한 사용자 JWT/RLS 흐름을 확인하는 예제에서 사용합니다.
