# Streamlit frontend가 호출할 FastAPI backend 주소
API_BASE_URL=http://127.0.0.1:8000

# Supabase DB
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis
# 이번 과정에서는 로컬 Redis를 설치하지 않고 Upstash Redis를 사용합니다.
# Upstash Console > Redis database > Connect/Details에서 rediss:// 로 시작하는 Redis URL을 복사합니다.
# Upstash Redis 예: rediss://default:password@host:port
# 비워 두면 수업용 메모리 큐 fallback으로 SSE가 동작합니다.
REDIS_URL=

# Optional. 02_supabase-ai-backend에서 배운 Upstash REST TTL/cache 흐름을 확장할 때 사용합니다.
# 01_realtime-log-dashboard-practice의 SSE 실습에서는 사용하지 않으며,
# 최종 미니 프로젝트에서 cache/session/rate-limit 기능을 추가할 때 참고합니다.
# Upstash Console > Redis database > REST API에서 HTTPS endpoint와 token을 복사합니다.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 배포 시 CORS 허용 주소
# Streamlit frontend가 FastAPI backend를 호출할 수 있도록 허용할 주소입니다.
# 현재 예제는 Python httpx 방식으로 SSE를 수신하므로 일반적으로 localhost/127.0.0.1만 있으면 됩니다.
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
