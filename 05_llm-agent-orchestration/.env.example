# 05_llm-agent-orchestration common environment example
#
# Copy this file to .env only when you want to run examples from the course root.
# Some units also provide their own .env.example files.
# Never commit a real .env file to GitHub.

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional local LLM through Docker/Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Docker PostgreSQL + pgvector
DATABASE_URL=postgresql://agent_user:agent_password@localhost:5433/agent_db

# Docker Redis
REDIS_URL=redis://localhost:6379/0

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=aidev-agent-orchestration

# Optional mock API target used in Tool examples
MOCK_API_BASE_URL=http://127.0.0.1:8000
