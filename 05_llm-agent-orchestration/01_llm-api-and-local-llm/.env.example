# OpenAI API를 호출할 때 사용하는 키입니다.
# 실제 키는 .env.example이 아니라 .env 파일에 입력합니다.
OPENAI_API_KEY=your-openai-api-key

# OpenAI 실습의 기본 모델입니다.
OPENAI_MODEL=gpt-4.1-mini

# Docker 컨테이너에서 실행되는 Ollama REST API 주소입니다.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama에 다운로드해서 사용할 로컬 Llama 모델명입니다.
OLLAMA_MODEL=llama3.2
