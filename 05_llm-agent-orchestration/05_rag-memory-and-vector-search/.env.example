# OpenAI API Key입니다.
# 05 단원에서는 임베딩 생성과 RAG 답변 생성 예제에서 사용합니다.
OPENAI_API_KEY=your-openai-api-key

# RAG 답변 생성에 사용할 기본 OpenAI 채팅 모델입니다.
OPENAI_CHAT_MODEL=gpt-4.1-mini

# 텍스트를 벡터로 변환할 때 사용할 임베딩 모델입니다.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Docker로 실행한 pgvector PostgreSQL 접속 주소입니다.
# README.md의 docker run 명령과 같은 DB 이름, 사용자, 비밀번호, 포트를 사용합니다.
DATABASE_URL=postgresql://agent_user:agent_password@localhost:5433/agent_db

# Docker로 실행한 Redis 접속 주소입니다.
# Session Memory와 cache 예제에서 사용합니다.
REDIS_URL=redis://localhost:6379/0
