# 07_multi-agent-service-ops 공통 환경 변수 예시입니다.
# 실제 값은 .env에 작성하고 GitHub에 올리지 않습니다.

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

API_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8801
MONITOR_URL=http://127.0.0.1:8802

# AWS 실습 기본값입니다. 실제 계정과 리전에 맞게 수정합니다.
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY_NAME=aidev-auto-healing-agent
APP_RUNNER_SERVICE_NAME=aidev-auto-healing-agent

# 운영 실습용 샘플 값입니다.
LOG_LEVEL=INFO
USE_MOCK_AGENT=true
