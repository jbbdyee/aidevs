# 실행 환경 이름입니다. local, dev, prod처럼 환경을 구분할 때 사용합니다.
APP_ENV=local

# backend FastAPI 서비스 포트입니다.
BACKEND_PORT=8000

# frontend Streamlit 서비스 포트입니다.
FRONTEND_PORT=8801

# monitor Streamlit 서비스 포트입니다.
MONITOR_PORT=8802

# frontend와 monitor가 호출할 backend 내부 주소입니다.
BACKEND_URL=http://backend:8000

# 장애 복구 재시도 횟수 예시입니다.
MAX_RETRY_COUNT=2

# AWS 배포 실습에서 사용할 리전 예시입니다.
AWS_REGION=ap-northeast-2
